<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Healthy Foodie</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; background: linear-gradient(135deg, #28a745 0%, #20c997 100%); min-height: 100vh; display: flex; justify-content: center; align-items: center;">
    <div style="background-color: white; padding: 2.5rem; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); width: 100%; max-width: 400px; margin: 20px;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <i class="fas fa-leaf" style="color: #28a745; font-size: 2rem; margin-bottom: 1rem;"></i>
            <h1 style="color: #333; font-size: 2rem; margin: 0;">Sign Up</h1>
            <p style="color: #666; margin-top: 0.5rem;">Join the Healthy Foodie community</p>
        </div>

        <form action="/signup" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label for="username" style="color: #333; font-weight: 500;">Username:</label>
                <input type="text" id="username" name="username" required 
                    style="padding: 0.8rem; border: 2px solid #e0e0e0; border-radius: 5px; font-size: 1rem; transition: border-color 0.3s; outline: none;"
                    onFocus="this.style.borderColor='#28a745';"
                    onBlur="this.style.borderColor='#e0e0e0';">
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label for="password" style="color: #333; font-weight: 500;">Password:</label>
                <input type="password" id="password" name="password" required 
                    style="padding: 0.8rem; border: 2px solid #e0e0e0; border-radius: 5px; font-size: 1rem; transition: border-color 0.3s; outline: none;"
                    onFocus="this.style.borderColor='#28a745';"
                    onBlur="this.style.borderColor='#e0e0e0';">
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label for="role" style="color: #333; font-weight: 500;">Role:</label>
                <select id="role" name="role" required 
                    style="padding: 0.8rem; border: 2px solid #e0e0e0; border-radius: 5px; font-size: 1rem; transition: border-color 0.3s; outline: none; background-color: white;"
                    onFocus="this.style.borderColor='#28a745';"
                    onBlur="this.style.borderColor='#e0e0e0';">
                    <option value="seller">Seller</option>
                    <option value="user">User</option>
                </select>
            </div>

            <button type="submit" 
                style="background-color: #28a745; color: white; padding: 1rem; border: none; border-radius: 5px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background-color 0.3s; margin-top: 1rem;"
                onMouseOver="this.style.backgroundColor='#218838';"
                onMouseOut="this.style.backgroundColor='#28a745';">
                Sign Up
            </button>
        </form>

        <div style="text-align: center; margin-top: 1.5rem;">
            <p style="color: #666; margin: 0;">Already have an account? 
                <a href="/login" style="color: #28a745; text-decoration: none; font-weight: 500;">Login here</a>
            </p>
        </div>
    </div>
</body>
</html>